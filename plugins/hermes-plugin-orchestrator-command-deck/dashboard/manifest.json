      "label": "Control",
      "path": "/orchestrator"
    },
    {
      "label": "Queue",
      "path": "/orchestrator/queue"
    },
    {
      "label": "Logs",
      "path": "/orchestrator/logs"
    }
  ],
  "entry": "dist/index.js",
  "slots": ["global-injector"]
}
