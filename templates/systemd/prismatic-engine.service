[Unit]
Description=Prismatic Engine — Agent Orchestration Hub
After=network.target

[Service]
Type=simple
User=prismatic
Environment=LINEAR_API_KEY=%i
Environment=LINEAR_TEAM_ID=GRO
ExecStart=/usr/local/bin/prismatic-engine serve
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
