# ============================================================
# Prismatic Engine — Portable Environment Variables Template
# ============================================================
# Copy this file to .env and configure the values for your host.
# DO NOT commit .env to version control.
# .env.template is committed so other operators can mirror the
# schema. Keep this file free of real secrets and free of
# /home/<user> absolute paths — use ~ or $HOME.

# --- Paths & Directories ---
HERMES_ROOT=~/.hermes
HERMES_PROFILE=orchestrator
AGY_SKILLS_DIR=~/.hermes/profiles/orchestrator/skills
AGY_BRAIN_DIR=~/.hermes/profiles/orchestrator/home/.gemini/antigravity-cli/brain
AGY_CONFIG_DIR=~/.antigravity
AGY_CONFIG_FILE=~/.antigravity/config.json
PRISMATIC_HOME=~/work/prismatic-engine
SOVEREIGN_HOME=~/work/SovereignSentinel
WORK_ROOT=~/work

# --- SSE Gateway ---
SSE_GATEWAY_HOST=localhost
SSE_GATEWAY_PORT=8644
SSE_GATEWAY_URL=http://localhost:8644

# --- Model Routing ---
AGY_MODEL_DEFAULT=gemini-3.1-flash
AGY_MODEL_PRO=gemini-3.1-pro-high
AGY_MODEL_SONNET=claude-3.5-sonnet
AGY_MODEL_FLASH=gemini-3.1-flash-lite

# --- API Credentials (replace with your own; never commit real values) ---
LINEAR_API_KEY=
LINEAR_OAUTH_TOKEN=
GITHUB_TOKEN=
GITHUB_PAT_KEY=
JULES_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_OAUTH_TOKEN=
TELEGRAM_BOT_TOKEN=

# --- Execution & Logging ---
AGY_LOG_LEVEL=INFO
AGY_AUDIT_OUTPUT_DIR=/tmp/

# --- Options ---
COMPAT_MODE=1        # Create $HOME symlinks for compatibility
SMOKE_TEST=0         # Run smoke test after deploy
