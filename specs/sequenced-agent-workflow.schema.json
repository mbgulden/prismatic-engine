{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prismatic-engine.local/schemas/sequenced-agent-workflow.schema.json",
  "title": "Prismatic Engine Sequenced Agent Workflow",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_id",
    "name",
    "version",
    "owner_agent",
    "identity",
    "sequencing",
    "steps",
    "verification_gates"
  ],
  "properties": {
    "workflow_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "owner_agent": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["venture_or_system"],
      "properties": {
        "venture_or_system": {
          "type": "string",
          "minLength": 1
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9.-]+$"
          },
          "uniqueItems": true
        },
        "repositories": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "remote": {"type": "string"},
              "local_path": {"type": "string"},
              "covers_domains": {
                "type": "array",
                "items": {"type": "string", "pattern": "^[a-z0-9.-]+$"},
                "uniqueItems": true
              }
            }
          }
        },
        "deployments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["provider", "name"],
            "properties": {
              "provider": {"type": "string"},
              "name": {"type": "string"},
              "url": {"type": "string"},
              "covers_domains": {
                "type": "array",
                "items": {"type": "string", "pattern": "^[a-z0-9.-]+$"},
                "uniqueItems": true
              }
            }
          }
        },
        "linear_project": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": {"type": "string"},
            "name": {"type": "string"}
          }
        }
      }
    },
    "sequencing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "max_active_agent_steps", "activation_strategy"],
      "properties": {
        "mode": {"const": "serial"},
        "max_active_agent_steps": {"type": "integer", "const": 1},
        "activation_strategy": {
          "type": "string",
          "enum": ["linear_label_gate", "file_gate", "manual_gate"]
        },
        "activation_label": {"type": "string"},
        "done_label": {"type": "string"}
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "owner_agent", "depends_on", "state", "expected_outputs"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
          "title": {"type": "string", "minLength": 1},
          "owner_agent": {"type": "string", "minLength": 1},
          "linear_issue": {"type": "string", "pattern": "^[A-Z]+-[0-9]+$"},
          "depends_on": {
            "type": "array",
            "items": {"type": "string"},
            "uniqueItems": true
          },
          "state": {
            "type": "string",
            "enum": ["blocked", "ready", "active", "done", "cancelled"]
          },
          "agent_labels_when_active": {
            "type": "array",
            "items": {"type": "string"},
            "uniqueItems": true
          },
          "expected_outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "description"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["file", "linear_issue", "linear_comment", "report", "cron_job", "deployment", "other"]
                },
                "path": {"type": "string"},
                "description": {"type": "string", "minLength": 1}
              }
            }
          },
          "verification": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "verification_gates": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "machine_reports": {"type": "string", "enum": ["autobot", "local"]},
        "human_decisions": {"type": "string", "enum": ["fred_telegram", "slack", "linear"]},
        "cron_default": {"type": "string", "enum": ["local", "origin", "autobot"]}
      }
    }
  }
}
